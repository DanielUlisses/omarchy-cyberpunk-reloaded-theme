  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#9a9f17", "fontStyle": "italic" }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.other.special-method",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#fee801" }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function",
        "keyword.other.special-method"
      ],
      "settings": { "foreground": "#54c1e6" }
    },
    {
      "name": "Class / Type",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class",
        "meta.class"
      ],
      "settings": { "foreground": "#fee801" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#39c4b6" }
    },
    {
      "name": "String escape / special",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#54c1e6" }
    },
    {
      "name": "Number / Constant",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.other",
        "constant.character"
      ],
      "settings": { "foreground": "#fee801" }
    },
    {
      "name": "Boolean",
      "scope": ["constant.language.boolean"],
      "settings": { "foreground": "#fee801" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other", "variable.language.this"],
      "settings": { "foreground": "#d8eef8" }
    },
    {
      "name": "Variable - parameter",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#54c1e6", "fontStyle": "italic" }
    },
    {
      "name": "Property / Member",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.property-name"
      ],
      "settings": { "foreground": "#54c1e6" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "punctuation.operator"],
      "settings": { "foreground": "#54c1e6" }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": { "foreground": "#d8eef8aa" }
    },
    {
      "name": "Import / Module",
      "scope": [
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.export",
        "entity.name.module",
        "support.module"
      ],
      "settings": { "foreground": "#54c1e6" }
    },
    {
      "name": "Tag name",
      "scope": ["entity.name.tag", "meta.tag"],
      "settings": { "foreground": "#fee801" }
    },
    {
      "name": "Tag attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#54c1e6" }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#54c1e6" }
    },
    {
      "name": "CSS value",
      "scope": ["support.property-value.css", "constant.other.color"],
      "settings": { "foreground": "#39c4b6" }
    },
    {
      "name": "CSS selector",
      "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css"],
      "settings": { "foreground": "#fee801" }
    },
    {
      "name": "Decorator / Annotation",
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#9a9f17", "fontStyle": "italic" }
    },
    {
      "name": "Markdown heading",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#fee801", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#fee801", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#54c1e6", "fontStyle": "italic" }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#39c4b6" }
    },
    {
      "name": "Markdown link",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#54c1e6", "fontStyle": "underline" }
    },
    {
      "name": "Diff added",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#39c4b6" }
    },
    {
      "name": "Diff removed",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#fee801" }
    },
    {
      "name": "Diff changed",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#9a9f17" }
    },
    {
      "name": "JSON key",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#54c1e6" }
    },
    {
      "name": "YAML key",
      "scope": ["entity.name.tag.yaml"],
      "settings": { "foreground": "#54c1e6" }
    },
    {
      "name": "Invalid / deprecated",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": { "foreground": "#d8eef8", "fontStyle": "strikethrough" }
    }
  ]
}
